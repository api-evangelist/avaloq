{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/avaloq/refs/heads/main/json-schema/banking-customer-list-schema.json",
  "title": "CustomerList",
  "description": "Paginated list of customers",
  "type": "object",
  "properties": {
    "data": {
      "type": "array",
      "items": {
        "$ref": "#/components/schemas/Customer"
      }
    },
    "total": {
      "type": "integer",
      "example": 1250
    },
    "offset": {
      "type": "integer",
      "example": 0
    }
  }
}